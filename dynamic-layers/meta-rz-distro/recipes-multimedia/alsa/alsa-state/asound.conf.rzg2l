pcm.!default {
    type asym
    playback.pcm "plug:dmix_hw"
    capture.pcm "hw:0,0"
}

pcm.dmix_hw {
    type dmix
    ipc_key 5678293
    ipc_perm 0666
    slave {
        pcm "hw:0,0"
        rate 48000
        channels 2
        format S32_LE
        period_time 20000
        buffer_time 240000
    }
    bindings {
        0 0
        1 1
    }
}

ctl.!default {
    type hw
    card 0
}
