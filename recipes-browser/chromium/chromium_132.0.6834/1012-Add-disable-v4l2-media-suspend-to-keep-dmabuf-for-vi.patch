From a0cd07d217b7071548a5e22afffbeec1e1d3950d Mon Sep 17 00:00:00 2001
From: Takuro Ashie <ashie@clear-code.com>
Date: Thu, 30 Apr 2026 18:48:29 +0900
Subject: [PATCH] Add --disable-v4l2-media-suspend to keep dmabuf for video
 preview

Upstream-Status: Inappropriate [oe specific]

Signed-off-by: Takuro Ashie <ashie@clear-code.com>
---
 content/browser/renderer_host/render_process_host_impl.cc | 3 +++
 media/base/media_switches.cc                              | 6 ++++++
 media/base/media_switches.h                               | 3 +++
 .../renderer/platform/media/web_media_player_impl.cc      | 8 ++++++++
 4 files changed, 20 insertions(+)

diff --git a/content/browser/renderer_host/render_process_host_impl.cc b/content/browser/renderer_host/render_process_host_impl.cc
index 10a3e987de..c4b9859d41 100644
--- a/content/browser/renderer_host/render_process_host_impl.cc
+++ b/content/browser/renderer_host/render_process_host_impl.cc
@@ -3308,6 +3308,9 @@ void RenderProcessHostImpl::PropagateBrowserCommandLineToRenderer(
       switches::kDisableHistogramCustomizer,
       switches::kDisableLCDText,
       switches::kDisableBackgroundMediaSuspend,
+#if BUILDFLAG(IS_CHROMEOS) || BUILDFLAG(IS_LINUX)
+      switches::kDisableV4L2MediaSuspend,
+#endif
       switches::kDisableNotifications,
       switches::kDisableOriginTrialControlledBlinkFeatures,
       switches::kDisablePresentationAPI,
diff --git a/media/base/media_switches.cc b/media/base/media_switches.cc
index 7050a1da9f..dd5daf380a 100644
--- a/media/base/media_switches.cc
+++ b/media/base/media_switches.cc
@@ -55,6 +55,12 @@ const char kVideoThreads[] = "video-threads";
 const char kDisableBackgroundMediaSuspend[] =
     "disable-background-media-suspend";
 
+#if BUILDFLAG(IS_CHROMEOS) || BUILDFLAG(IS_LINUX)
+// Never suspend v4l2 decoder to preserve decoded preview image.
+const char kDisableV4L2MediaSuspend[] =
+    "disable-v4l2-media-suspend";
+#endif
+
 // Force to report VP9 as an unsupported MIME type.
 const char kReportVp9AsAnUnsupportedMimeType[] =
     "report-vp9-as-an-unsupported-mime-type";
diff --git a/media/base/media_switches.h b/media/base/media_switches.h
index 75dd5b64e8..74e2650dd2 100644
--- a/media/base/media_switches.h
+++ b/media/base/media_switches.h
@@ -40,6 +40,9 @@ MEDIA_EXPORT extern const char kFailAudioStreamCreation[];
 MEDIA_EXPORT extern const char kVideoThreads[];
 
 MEDIA_EXPORT extern const char kDisableBackgroundMediaSuspend[];
+#if BUILDFLAG(IS_CHROMEOS) || BUILDFLAG(IS_LINUX)
+MEDIA_EXPORT extern const char kDisableV4L2MediaSuspend[];
+#endif
 
 MEDIA_EXPORT extern const char kReportVp9AsAnUnsupportedMimeType[];
 
diff --git a/third_party/blink/renderer/platform/media/web_media_player_impl.cc b/third_party/blink/renderer/platform/media/web_media_player_impl.cc
index 921d37e1da..037ba121fb 100644
--- a/third_party/blink/renderer/platform/media/web_media_player_impl.cc
+++ b/third_party/blink/renderer/platform/media/web_media_player_impl.cc
@@ -3214,6 +3214,14 @@ void WebMediaPlayerImpl::SetSuspendState(bool is_suspended) {
   DCHECK(main_task_runner_->BelongsToCurrentThread());
   DVLOG(2) << __func__ << "(" << is_suspended << ")";
 
+#if BUILDFLAG(IS_CHROMEOS) || BUILDFLAG(IS_LINUX)
+  if (video_decoder_type_ == media::VideoDecoderType::kV4L2 &&
+      base::CommandLine::ForCurrentProcess()->HasSwitch(
+          switches::kDisableV4L2MediaSuspend)) {
+    is_suspended = false;
+  }
+#endif
+
   // Do not change the state after an error has occurred.
   // TODO(sandersd): Update PipelineController to remove the need for this.
   if (IsNetworkStateError(network_state_))
-- 
2.43.0

